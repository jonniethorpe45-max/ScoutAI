NODE_ENV=development
LOG_LEVEL=info

WEB_PORT=3000
API_PORT=4000

APP_URL=http://localhost:3000
API_URL=http://localhost:4000

DATABASE_URL=postgresql://scoutai:scoutai@127.0.0.1:5432/scoutai?schema=public
REDIS_URL=redis://127.0.0.1:6379

# Min 32 characters. Generate a unique value for every environment.
SESSION_SECRET=dev-only-change-me-to-a-long-random-string
SESSION_COOKIE_NAME=scoutai_session
SESSION_TTL_SECONDS=604800

# CORS / cookie
CORS_ORIGIN=http://localhost:3000
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Web app (also set in apps/web/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:4000
